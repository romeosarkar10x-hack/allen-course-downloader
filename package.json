{
    "name": "allen-course-downloader",
    "version": "1.0.0",
    "description": "Download all of your videos from `allen.in`.",
    "type": "module",
    "main": "fetch.js",
    "scripts": {
        "test": "vitest run --coverage",
        "format:check": "prettier \"**/*.{ts,json,yml,yaml}\" --check --debug-check --ignore-path .prettierignore",
        "format": "prettier \"**/*.{ts,json,yml,yaml}\" --write --ignore-path .prettierignore",
        "lint": "eslint --flag unstable_native_nodejs_ts_config .",
        "type-check": "tsc -p tsconfig.node.json && tsc -p tsconfig.test.json",
        "dry-run": "node esbuild.ts && node dist/dry-run.cjs",
        "prepare": "git config core.hooksPath .githooks"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/romeosarkar10x-hack/allen-course-downloader.git"
    },
    "author": "Romeo Sarkar",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/romeosarkar10x-hack/allen-course-downloader/issues"
    },
    "homepage": "https://github.com/romeosarkar10x-hack/allen-course-downloader#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "4.1.7",
        "eslint": "^10.4.0",
        "globals": "^17.6.0",
        "node-jq": "^6.3.1",
        "prettier": "^3.8.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vitest": "^4.1.7"
    },
    "dependencies": {
        "@types/lodash": "^4.17.24",
        "dotenv": "^16.6.1",
        "esbuild": "^0.28.0",
        "lodash": "^4.18.1",
        "neverthrow": "^8.2.0",
        "zod": "^4.4.3"
    }
}
