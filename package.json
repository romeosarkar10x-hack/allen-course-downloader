        "format": "prettier \"**/*.{html,css,js,jsx,json,yml,yaml}\" --write --ignore-path .prettierignore",
        "lint": "eslint --flag unstable_native_nodejs_ts_config . -f json | node-jq -r '.[].filePath'"
    },
